generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dailySummaries  DailySummary[]
  customExercises Exercise[]
  customFoods     Food[]
  meals           Meal[]
  progressLogs    ProgressLog[]
  refreshTokens   RefreshToken[]
  goals           UserGoals?
  profile         UserProfile?
  workouts        Workout[]

  @@map("users")
}

model UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?
  gender          String?
  heightCm        Float?
  currentWeightKg Float?
  activityLevel   String    @default("SEDENTARY")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserGoals {
  id                   String   @id @default(uuid())
  userId               String   @unique
  goalType             String   @default("MAINTAIN")
  targetWeightKg       Float?
  weeklyWeightChangeKg Float?
  dailyCalories        Int?
  dailyProteinG        Int?
  dailyCarbsG          Int?
  dailyFatG            Int?
  dailyFiberG          Int?
  dailyWaterMl         Int?
  useCustomMacros      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Food {
  id              String      @id @default(uuid())
  name            String
  brand           String?
  barcode         String?
  servingSizeG    Float       @default(100)
  servingUnit     String      @default("g")
  caloriesKcal    Float
  proteinG        Float
  carbsG          Float
  fatG            Float
  fiberG          Float?
  sugarG          Float?
  sodiumMg        Float?
  saturatedFatG   Float?
  cholesterolMg   Float?
  isVerified      Boolean     @default(false)
  isCustom        Boolean     @default(false)
  createdByUserId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       User?       @relation(fields: [createdByUserId], references: [id])
  mealEntries     MealEntry[]

  @@index([name])
  @@index([barcode])
  @@map("foods")
}

model Meal {
  id            String      @id @default(uuid())
  userId        String
  name          String?
  mealType      String
  loggedAt      DateTime    @default(now())
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  totalCalories Float?
  totalProteinG Float?
  totalCarbsG   Float?
  totalFatG     Float?
  entries       MealEntry[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("meals")
}

model MealEntry {
  id           String   @id @default(uuid())
  mealId       String
  foodId       String
  servings     Float    @default(1)
  customGrams  Float?
  caloriesKcal Float
  proteinG     Float
  carbsG       Float
  fatG         Float
  createdAt    DateTime @default(now())
  food         Food     @relation(fields: [foodId], references: [id])
  meal         Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_entries")
}

model Exercise {
  id              String         @id @default(uuid())
  name            String
  description     String?
  category        String
  muscleGroups    String?
  caloriesPerMin  Float?
  isWeighted      Boolean        @default(true)
  isBodyweight    Boolean        @default(false)
  isCustom        Boolean        @default(false)
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       User?          @relation(fields: [createdByUserId], references: [id])
  workoutEntries  WorkoutEntry[]

  @@index([name])
  @@index([category])
  @@map("exercises")
}

model Workout {
  id                  String         @id @default(uuid())
  userId              String
  name                String?
  workoutType         String
  startedAt           DateTime
  endedAt             DateTime?
  durationMin         Int?
  notes               String?
  totalCaloriesBurned Float?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  entries             WorkoutEntry[]
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("workouts")
}

model WorkoutEntry {
  id             String   @id @default(uuid())
  workoutId      String
  exerciseId     String
  orderIndex     Int      @default(0)
  sets           Int?
  reps           Int?
  weightKg       Float?
  durationMin    Float?
  distanceKm     Float?
  avgHeartRate   Int?
  caloriesBurned Float?
  notes          String?
  createdAt      DateTime @default(now())
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  workout        Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@map("workout_entries")
}

model ProgressLog {
  id         String   @id @default(uuid())
  userId     String
  loggedAt   DateTime @default(now())
  weightKg   Float?
  bodyFatPct Float?
  waistCm    Float?
  hipsCm     Float?
  chestCm    Float?
  armsCm     Float?
  thighsCm   Float?
  notes      String?
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("progress_logs")
}

model DailySummary {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime
  caloriesConsumed Float    @default(0)
  proteinG         Float    @default(0)
  carbsG           Float    @default(0)
  fatG             Float    @default(0)
  fiberG           Float    @default(0)
  waterMl          Float    @default(0)
  caloriesBurned   Float    @default(0)
  workoutMinutes   Int      @default(0)
  calorieGoal      Int?
  proteinGoal      Int?
  carbsGoal        Int?
  fatGoal          Int?
  netCalories      Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_summaries")
}
