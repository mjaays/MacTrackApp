// MacTrack Database Schema
// Prisma with SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ==================== USER & AUTH ====================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  profile        UserProfile?
  goals          UserGoals?
  refreshTokens  RefreshToken[]
  meals          Meal[]
  workouts       Workout[]
  progressLogs   ProgressLog[]
  dailySummaries DailySummary[]
  customFoods    Food[]
  customExercises Exercise[]

  @@map("users")
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?
  gender          String?  // MALE, FEMALE, OTHER
  heightCm        Float?
  currentWeightKg Float?
  activityLevel   String   @default("SEDENTARY") // SEDENTARY, LIGHTLY_ACTIVE, MODERATELY_ACTIVE, VERY_ACTIVE, EXTRA_ACTIVE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserGoals {
  id                   String   @id @default(uuid())
  userId               String   @unique
  goalType             String   @default("MAINTAIN") // LOSE_WEIGHT, MAINTAIN, GAIN_WEIGHT, GAIN_MUSCLE, RECOMPOSITION
  targetWeightKg       Float?
  weeklyWeightChangeKg Float?   // e.g., -0.5 for losing 0.5kg/week

  // Calculated or custom targets
  dailyCalories  Int?
  dailyProteinG  Int?
  dailyCarbsG    Int?
  dailyFatG      Int?
  dailyFiberG    Int?
  dailyWaterMl   Int?

  // Override auto-calculation
  useCustomMacros Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==================== FOOD & MEALS ====================

model Food {
  id           String  @id @default(uuid())
  name         String
  brand        String?
  barcode      String?
  servingSizeG Float   @default(100)
  servingUnit  String  @default("g")

  // Nutritional data per serving
  caloriesKcal  Float
  proteinG      Float
  carbsG        Float
  fatG          Float
  fiberG        Float?
  sugarG        Float?
  sodiumMg      Float?
  saturatedFatG Float?
  cholesterolMg Float?

  // Metadata
  isVerified      Boolean  @default(false)
  isCustom        Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  createdBy   User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  mealEntries MealEntry[]

  @@index([name])
  @@index([barcode])
  @@map("foods")
}

model Meal {
  id        String   @id @default(uuid())
  userId    String
  name      String?  // e.g., "Breakfast", "Lunch", custom name
  mealType  String   // BREAKFAST, LUNCH, DINNER, SNACK, OTHER
  loggedAt  DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries MealEntry[]

  // Calculated totals (denormalized for performance)
  totalCalories Float?
  totalProteinG Float?
  totalCarbsG   Float?
  totalFatG     Float?

  @@index([userId, loggedAt])
  @@map("meals")
}

model MealEntry {
  id          String  @id @default(uuid())
  mealId      String
  foodId      String
  servings    Float   @default(1)
  customGrams Float?  // Override serving size

  // Snapshot of nutritional values at time of logging
  caloriesKcal Float
  proteinG     Float
  carbsG       Float
  fatG         Float

  createdAt DateTime @default(now())

  // Relations
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@map("meal_entries")
}

// ==================== EXERCISE & WORKOUTS ====================

model Exercise {
  id             String  @id @default(uuid())
  name           String
  description    String?
  category       String  // CARDIO, STRENGTH, FLEXIBILITY, BALANCE, SPORTS, OTHER
  muscleGroups   String? // Comma-separated: CHEST,BACK,SHOULDERS etc.

  // For cardio: calories burned per minute at moderate intensity
  caloriesPerMin Float?

  // For strength: default metrics
  isWeighted   Boolean @default(true)
  isBodyweight Boolean @default(false)

  // Metadata
  isCustom        Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  createdBy      User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  workoutEntries WorkoutEntry[]

  @@index([name])
  @@index([category])
  @@map("exercises")
}

model Workout {
  id          String    @id @default(uuid())
  userId      String
  name        String?   // e.g., "Push Day", "Morning Run"
  workoutType String    // STRENGTH, CARDIO, HIIT, FLEXIBILITY, SPORTS, MIXED, OTHER
  startedAt   DateTime
  endedAt     DateTime?
  durationMin Int?
  notes       String?

  // Calculated totals
  totalCaloriesBurned Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WorkoutEntry[]

  @@index([userId, startedAt])
  @@map("workouts")
}

model WorkoutEntry {
  id         String @id @default(uuid())
  workoutId  String
  exerciseId String
  orderIndex Int    @default(0)

  // Strength training data
  sets     Int?
  reps     Int?
  weightKg Float?

  // Cardio data
  durationMin  Float?
  distanceKm   Float?
  avgHeartRate Int?

  // Calculated
  caloriesBurned Float?

  notes     String?
  createdAt DateTime @default(now())

  // Relations
  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@map("workout_entries")
}

// ==================== PROGRESS TRACKING ====================

model ProgressLog {
  id       String   @id @default(uuid())
  userId   String
  loggedAt DateTime @default(now())

  // Body measurements
  weightKg   Float?
  bodyFatPct Float?

  // Body circumferences (cm)
  waistCm  Float?
  hipsCm   Float?
  chestCm  Float?
  armsCm   Float?
  thighsCm Float?

  // Additional data
  notes    String?
  photoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("progress_logs")
}

// ==================== DAILY SUMMARIES ====================

model DailySummary {
  id     String   @id @default(uuid())
  userId String
  date   DateTime

  // Nutrition totals
  caloriesConsumed Float @default(0)
  proteinG         Float @default(0)
  carbsG           Float @default(0)
  fatG             Float @default(0)
  fiberG           Float @default(0)
  waterMl          Float @default(0)

  // Exercise totals
  caloriesBurned Float @default(0)
  workoutMinutes Int   @default(0)

  // Goals at time of logging
  calorieGoal Int?
  proteinGoal Int?
  carbsGoal   Int?
  fatGoal     Int?

  // Net calculations
  netCalories Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_summaries")
}
